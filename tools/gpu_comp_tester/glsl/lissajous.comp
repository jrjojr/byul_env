#version 430
layout (local_size_x = 1) in;

layout(std140, binding = 0) uniform RotatorLerp {
    vec4 a;
    vec4 b;
    vec4 params; // y: elapsed seconds
} ubo;

layout(std430, binding = 1) buffer Result {
    vec4 rotated;
};

void main() {
    float time = ubo.params.y;
    vec3 point = vec3(0.65 * sin(time * 1.7),
                      0.45 * sin(time * 3.4),
                      0.0);
    rotated = vec4(point, 1.0);
}
