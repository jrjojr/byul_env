// debug시에만 문자열 출력하기
#ifndef DEBUG_PRINT
    #ifdef DEBUG
        #define DEBUG_PRINT(fmt, ...) do { \
                fprintf(stdout, fmt, __VA_ARGS__); \
            } while (0)
    #else
        #define DEBUG_PRINT(fmt, ...) do { } while (0)
    #endif // DEBUG
#endif // DEBUG_PRINT

