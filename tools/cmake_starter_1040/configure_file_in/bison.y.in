* All Rights Reserved.
*
* ${PROJECT_NAME} 
*
* 이 파일로 헤더 파일 : ${aBisonHFilename}, 소스파일 : ${aBisonCFilename} 생성한다.
* 헤더 파일과 소스 파일을 수정하고 싶으면, ${PROJECT_NAME}.y 파일을 수정한 뒤에
* 아래 라인을 실행해서 헤더 파일과 소스 파일을 다시 생성하는 것이 정상적인 방법이다.
*       ${aBisonPath} ${BISON_ARGS}
*
* 그냥 헤더 파일과 소스 파일을 수정해도 되지만, 정상적인 방법이 아니다.
* 이 코드 블럭은 헤더 파일과 소스파일 두 개의 파일에서 
* 공통적으로 파일의 가장 윗 부분에 적용되는 블럭이다.
*
* 헤더 파일에 정의된다. YYSTYPE이 정의되기 전에...
*
***************************************************************************/

#ifdef __cplusplus
extern "C" {
#endif

#ifndef YY_TYPEDEF_YY_SCANNER_T
# define YY_TYPEDEF_YY_SCANNER_T
typedef void* yyscan_t;
#endif

#include "${PROJECT_NAME}/${PROJECT_NAME}_config.h"

  typedef struct
  {
    // Whether to print the intermediate results.
    int verbose;
    // Value of the last computation.
    int value;
    // Number of errors.
    int nerrs;
  } result;

  LIBAPI result parse_string (const char* cp);
  LIBAPI result parse (void);

#ifdef __cplusplus
}
#endif

}

%code provides{
// 헤더 파일에 정의된다. YYSTYPE이 정의되고 난 후에.,..

  // Tell Flex the expected prototype of yylex.
  // The scanner argument must be named yyscanner.
#define YY_DECL                                                         \
  yytoken_kind_t yylex (YYSTYPE* yylval, yyscan_t yyscanner, result *res)
  YY_DECL;

  void yyerror (yyscan_t scanner, result *res, const char *msg, ...);

}

%code top {
