# Python
__pycache__/
*.py[cod]
*.egg-info/
*.log

# Qt UI
*.qrc
*.ui

# C build artifacts
*.o
*.out
*.so
build/
build_*/
dist/
*.dll
*.exe
*.a
*.dylib

# macOS / Linux / Windows trash
.DS_Store
Thumbs.db

# 환경 파일 (선택적)
.env
*.env
secrets.txt

# vscode 환경 폴더
.vscode/
.venv/
.venv-package/

# zip 파일
*.zip

# image file
images/
!tools/python/byul_grid/assets/images/
!tools/python/byul_grid/assets/images/**

# 노트.org
byul/docs/

# external
# Keep machine-local packages ignored, but version reproducible build inputs.
external/*
!external/rules
